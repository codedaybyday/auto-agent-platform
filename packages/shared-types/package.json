{
  "name": "@auto-agent/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types for Auto Agent Platform",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.2"
  }
}
