{
  "mcpServers": {
    "nine-raptor": {
      "command": "npx",
      "args": [
        "-y",
        "--registry=http://r.npm.sankuai.com",
        "@nine/nine-ai@latest"
      ]
    },
    "api-mcp-tools": {
      "command": "npx",
      "args": [
        "-y",
        "--registry=http://r.npm.sankuai.com",
        "@wmfe/wmb-api-mcp-tools@1.0.2"
      ]
    },
    "knowledge-sync": {
      "command": "npx",
      "args": [
        "-y",
        "--registry=http://r.npm.sankuai.com",
        "@block/memory-hub@latest"
      ],
      "env": {
        "TEMPLATE_ID": "37"
      }
    },
    "ingee": {
      "url": "https://d2c.ai.test.sankuai.com/mcp"
    }
  }
}
