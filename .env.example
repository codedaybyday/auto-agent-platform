# ========================================
# Auto Agent Platform - Environment Variables
# ========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Database (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/autoagent

# Redis (for future use)
REDIS_URL=redis://localhost:6379

# LLM Configuration (Server-side only!)
# These are used by the server to call LLM APIs
# Users will NOT have access to these keys
DEFAULT_MODEL=claude-3-5-sonnet-20241022
DEFAULT_BASE_URL=https://api.anthropic.com
LLM_API_KEY=sk-ant-api03-your-api-key-here

# Client Configuration
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
