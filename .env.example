# ========================================
# Auto Agent Platform - Environment Variables
# ========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Database (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/autoagent

# Redis (for future use)
REDIS_URL=redis://localhost:6379

# ==========================================
# LLM Configuration (Server-side only!)
# 支持：Anthropic Claude / OpenAI / Ollama 本地部署 / 国产大模型
# ==========================================

# ------------------------------------------
# 方案1: Anthropic Claude（推荐）
# ------------------------------------------
DEFAULT_MODEL=claude-3-5-sonnet-20241022
DEFAULT_BASE_URL=https://api.anthropic.com
LLM_API_KEY=sk-ant-api03-your-api-key-here

# ------------------------------------------
# 方案2: OpenAI
# ------------------------------------------
# DEFAULT_MODEL=gpt-4
# DEFAULT_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key-here

# ------------------------------------------
# 方案3: Ollama 本地部署（无需 API Key，隐私优先）
# ------------------------------------------
# 使用步骤：
# 1. 安装 Ollama: https://ollama.com/download
# 2. 启动服务: ollama serve
# 3. 拉取模型: ollama pull llama3.2
# 4. 配置如下：
#
# DEFAULT_MODEL=llama3.2
# DEFAULT_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama

# Ollama 推荐模型：
# - llama3.2 (Meta, 适合英文任务)
# - qwen2.5 (阿里通义, 适合中文任务)
# - deepseek-coder (编程专用)
# - codellama (代码生成)
# - mistral (快速响应)

# Ollama 工具调用（实验性功能，默认关闭）
# LLM_ENABLE_TOOLS=false

# ------------------------------------------
# 方案4: 国产大模型（OpenAI 兼容格式）
# ------------------------------------------
# DeepSeek
# DEFAULT_MODEL=deepseek-chat
# DEFAULT_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-your-deepseek-key

# 阿里云通义千问
# DEFAULT_MODEL=qwen-max
# DEFAULT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-key

# ==========================================
# Client Configuration
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
