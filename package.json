{
  "name": "auto-agent-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Auto Agent Platform - Multi-model AI Agent with tools",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:client": "turbo run dev --filter=@auto-agent/client",
    "dev:server": "turbo run dev --filter=@auto-agent/server",
    "dev:seq": "pnpm dev:server > server.log 2>&1 & sleep 3 && pnpm dev:client > client.log",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "kill:server": "kill -9 $(lsof -t -i:3001) 2>/dev/null || echo 'Port 3001 is free'",
    "predev:server": "pnpm kill:server"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "electron-rebuild": "^3.2.9",
    "prettier": "^3.3.2",
    "turbo": "^2.0.0",
    "typescript": "^5.5.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
