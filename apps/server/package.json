{
  "name": "@auto-agent/server",
  "version": "0.0.0",
  "private": true,
  "description": "Auto Agent Server - Node.js backend",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@auto-agent/shared-types": "workspace:*",
    "@auto-agent/shared-utils": "workspace:*",
    "express": "^4.19.0",
    "ws": "^8.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/ws": "^8.5.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.5.0"
  }
}
